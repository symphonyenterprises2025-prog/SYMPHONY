# Database
DATABASE_URL="postgresql://user:password@host:5432/database"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Auth
NEXTAUTH_SECRET="change-this-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Payments
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# Storage
S3_ACCESS_KEY_ID="your-s3-access-key"
S3_SECRET_ACCESS_KEY="your-s3-secret-key"
S3_BUCKET="your-s3-bucket"
S3_REGION="us-east-1"

# Email (Brevo/Sendinblue)
BREVO_API_KEY="your-brevo-api-key"
BREVO_SENDER_EMAIL="your-sender-email"
BREVO_SENDER_NAME="Your Store Name"
ADMIN_EMAIL="your-admin-email"

# Analytics
NEXT_PUBLIC_GA_ID="your-google-analytics-id"

# WhatsApp Notifications (via OpenWA)
OPENWA_API_URL=http://localhost:2785/api
OPENWA_API_KEY=your-openwa-api-key
OPENWA_SESSION_ID=symphony
OPENWA_ADMIN_PHONE=917978974823
OPENWA_ENABLED=false

# Per-event notification channels (email | whatsapp | both)
NOTIFY_ORDER_CONFIRMED=both
NOTIFY_ORDER_SHIPPED=both
NOTIFY_ORDER_DELIVERED=both
NOTIFY_ORDER_CANCELLED=both
NOTIFY_AUTH_OTP=email
NOTIFY_AUTH_WELCOME=both
NOTIFY_CONTACT_INQUIRY=both
NOTIFY_CORPORATE_INQUIRY=both
NOTIFY_ADMIN_NEW_ORDER=whatsapp
NOTIFY_ADMIN_LARGE_ORDER=whatsapp
